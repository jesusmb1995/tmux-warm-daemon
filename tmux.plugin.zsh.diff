diff --git a/plugins/tmux/tmux.plugin.zsh b/plugins/tmux/tmux.plugin.zsh
index 11820ebb..b2fecad7 100644
--- a/plugins/tmux/tmux.plugin.zsh
+++ b/plugins/tmux/tmux.plugin.zsh
@@ -5,6 +5,10 @@ fi
 
 # CONFIGURATION VARIABLES
 : ${ZSH_TMUX_CD:=false}
+# When set, auto-attach targets a detached session whose name starts with this
+# prefix (e.g. "warm" matches "warm-0", "warm-1"). Prevents attaching to
+# sessions from other pools (like agent-*).
+: ${ZSH_TMUX_WARM_SESSION_PREFIX:=}
 # Automatically start tmux
 : ${ZSH_TMUX_AUTOSTART:=false}
 # Only autostart once. If set to false, tmux will attempt to
@@ -135,6 +139,11 @@ function _zsh_tmux_plugin_run() {
       session_name="$ZSH_TMUX_DEFAULT_SESSION_NAME"
   fi
 
+  if [[ -n "$ZSH_TMUX_WARM_SESSION_PREFIX" && -z "$session_name" ]]; then
+    session_name=$(command tmux list-sessions -F '#{session_name} #{session_attached}' 2>/dev/null \
+      | awk -v pfx="${ZSH_TMUX_WARM_SESSION_PREFIX}-" '$1 ~ "^"pfx && $2 == 0 { print $1; exit }')
+  fi
+
   # Try to connect to an existing session.
   if [[ -n "$ZSH_TMUX_CD" ]]; then
     prelaunch_pwd=$(pwd)
